<fieldset>
  <div class="form-group">
    <label>{{localize "BFREF.DIALOG.FORMULA"}}</label>
    <div class="form-fields">
      {{ formInput formula.field value=formula.value name="formula" type="text" }}
    </div>
  </div>

  <div class="form-group">
    <label>{{localize "BFREF.DIALOG.TYPES"}}</label>
    <div class="form-fields">
      <select name="healType">
        {{#each healingTypes}}
        <option value="{{value}}" {{#if (eq ../healType.value value)}}selected{{/if}}>{{label}}</option>
        {{/each}}
      </select>
    </div>
  </div>
</fieldset>